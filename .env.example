# ==============================================================================
# ROTA - Öğrenci Kariyer ve Rehberlik Platformu (.env.example)
# ==============================================================================
# Bu dosyayı projeyi klonlayan geliştiriciler `.env` olarak kopyalayarak
# kendi ortam değişkenlerini ayarlamalıdır:
#   Windows (PowerShell): Copy-Item .env.example .env
#   Linux/macOS:          cp .env.example .env
# ==============================================================================

# 1. VERİTABANI BAĞLANTISI (DATABASE_URL)
# Vercel Postgres / Neon veya Yerel PostgreSQL Bağlantı Adresi:
# Örnek PostgreSQL: DATABASE_URL="postgresql://kullanici:sifre@host:5432/veritabani?sslmode=require"
# Örnek Yerel SQLite (Eğer SQLite kullanıyorsanız): DATABASE_URL="file:./dev.db"
DATABASE_URL="postgresql://kullanici:sifre@localhost:5432/rota_db"

# 2. NEXTAUTH AYARLARI
# Güvenlik için rastgele bir gizli anahtar (örn. openssl rand -base64 32)
NEXTAUTH_SECRET="gorsel-ve-gizli-bir-anahtar-yazin-2026"
NEXTAUTH_URL="http://localhost:3000"

# 3. YAPAY ZEKA (GROQ API KEY)
# Yapay Zeka Destekli Hedef & Plan Sihirbazı için Groq API Anahtarı (https://console.groq.com)
GROQ_API_KEY="gsk_senin_groq_api_anahtarin"
